<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PARFUMĒRA — Présentation CSE</title>
  <style>
    /* ─── RESET & BASE ─────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-size: 16px;
      scroll-behavior: smooth;
    }

    body {
      background-color: #f5f3f1;
      font-family: 'Georgia', 'Times New Roman', serif;
      color: #2c2c2c;
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── WRAPPER ──────────────────────────────────────── */
    .wrapper {
      max-width: 900px;
      margin: 0 auto;
      padding: 60px 30px 80px;
    }

    /* ─── HEADER / LOGO ────────────────────────────────── */
    header {
      text-align: center;
      margin-bottom: 50px;
    }

    .logo-container {
      display: inline-block;
      margin-bottom: 10px;
    }

    .logo-container img {
      height: 90px;
      width: auto;
      display: block;
      margin: 0 auto;
      /* Si le logo n'est pas trouvé, le fallback texte s'affiche */
    }

    .logo-fallback {
      font-size: 2.4rem;
      font-weight: 700;
      letter-spacing: 0.25em;
      color: #2c2c2c;
      text-transform: uppercase;
      font-family: 'Georgia', serif;
      display: none; /* masqué si l'image charge */
    }

    /* Affiche le fallback si l'image échoue */
    .logo-container img.img-error + .logo-fallback {
      display: block;
    }

    /* ─── DIVIDER ORNEMENT ─────────────────────────────── */
    .ornament {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      margin: 32px 0 40px;
      color: #ceb794;
      font-size: 1.1rem;
      letter-spacing: 0.1em;
    }

    .ornament::before,
    .ornament::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(to right, transparent, #ceb794, transparent);
    }

    /* ─── INTRO TEXT ───────────────────────────────────── */
    .intro {
      text-align: center;
      font-size: 1.08rem;
      line-height: 1.9;
      color: #3a3a3a;
      max-width: 780px;
      margin: 0 auto 50px;
      font-style: italic;
    }

    .intro strong {
      font-style: normal;
      color: #2c2c2c;
    }

    /* ─── SECTION TITLES ───────────────────────────────── */
    .section-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: #2c2c2c;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      display: inline-block;
      padding-bottom: 10px;
      border-bottom: 2px solid #ceb794;
      margin-bottom: 22px;
    }

    .section-header {
      margin-bottom: 8px;
    }

    /* ─── SECTION BLOCKS ───────────────────────────────── */
    .section {
      margin-bottom: 50px;
    }

    .section p {
      font-size: 1rem;
      color: #3a3a3a;
      line-height: 1.9;
    }

    .section a {
      color: #a07840;
      text-decoration: none;
      border-bottom: 1px solid #ceb794;
      transition: color 0.25s, border-color 0.25s;
    }

    .section a:hover {
      color: #ceb794;
      border-color: #a07840;
    }

    /* ─── AVANTAGES BOX ────────────────────────────────── */
    .avantages-box {
      background-color: #ceb794;
      border-radius: 10px;
      padding: 38px 44px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10);
      margin-bottom: 50px;
    }

    .avantages-box .box-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: #2c2c2c;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.55);
      margin-bottom: 24px;
    }

    .avantages-list {
      list-style: none;
      padding: 0;
    }

    .avantages-list li {
      font-size: 0.97rem;
      color: #2a2a2a;
      padding: 9px 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.4);
      line-height: 1.7;
      display: flex;
      align-items: flex-start;
      gap: 10px;
    }

    .avantages-list li:last-child {
      border-bottom: none;
    }

    .avantages-list li::before {
      content: '—';
      color: rgba(44, 44, 44, 0.55);
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* ─── CATALOGUE SECTION ────────────────────────────── */
    .catalogue-section {
      text-align: center;
      margin-bottom: 50px;
    }

    .catalogue-section p {
      font-size: 1rem;
      color: #3a3a3a;
      line-height: 1.9;
      margin-bottom: 28px;
      font-style: italic;
    }

    /* ─── CTA BUTTON ───────────────────────────────────── */
    .btn-catalogue {
      display: inline-block;
      padding: 16px 42px;
      background-color: #2c2c2c;
      color: #f5f3f1;
      text-decoration: none;
      font-family: 'Georgia', serif;
      font-size: 0.92rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      border: 1.5px solid #2c2c2c;
      border-radius: 3px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.13);
      transition: background-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
      cursor: pointer;
      margin-bottom: 36px;
    }

    .btn-catalogue:hover {
      background-color: #ceb794;
      color: #2c2c2c;
      border-color: #ceb794;
      box-shadow: 0 8px 28px rgba(206, 183, 148, 0.35);
      transform: translateY(-2px);
    }

    .btn-catalogue:active {
      transform: translateY(0);
      box-shadow: 0 3px 10px rgba(0,0,0,0.10);
    }

    /* ─── TEXTE OFFRE PERSONNALISÉE ────────────────────── */
    .personalise-text {
      font-size: 1rem;
      color: #3a3a3a;
      line-height: 1.9;
      text-align: left;
    }

    .personalise-text p + p {
      margin-top: 16px;
    }

    /* ─── CONTACT SECTION ──────────────────────────────── */
    .contact-section {
      background-color: #fff;
      border-left: 3px solid #ceb794;
      border-radius: 6px;
      padding: 32px 38px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.07);
      margin-bottom: 40px;
    }

    .contact-section p {
      font-size: 0.99rem;
      color: #3a3a3a;
      line-height: 1.9;
    }

    .contact-section .contact-intro {
      font-style: italic;
      margin-bottom: 22px;
      padding-bottom: 18px;
      border-bottom: 1px solid #e8e2da;
    }

    .contact-card {
      margin-top: 6px;
    }

    .contact-card .contact-name {
      font-weight: 700;
      font-size: 1.05rem;
      color: #2c2c2c;
      letter-spacing: 0.05em;
      margin-bottom: 10px;
    }

    .contact-info {
      list-style: none;
      padding: 0;
    }

    .contact-info li {
      font-size: 0.97rem;
      color: #3a3a3a;
      padding: 5px 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .contact-info li .icon {
      color: #ceb794;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .contact-info a {
      color: #a07840;
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: color 0.25s, border-color 0.25s;
    }

    .contact-info a:hover {
      color: #ceb794;
      border-bottom-color: #ceb794;
    }

    /* ─── FOOTER ───────────────────────────────────────── */
    footer {
      text-align: center;
      padding-top: 40px;
      border-top: 1px solid #ddd8d0;
    }

    footer p {
      font-size: 0.8rem;
      color: #999;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .footer-logo {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.3em;
      color: #ceb794;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    /* ─── RESPONSIVE ───────────────────────────────────── */
    @media (max-width: 640px) {
      .wrapper {
        padding: 36px 20px 60px;
      }

      .logo-container img {
        height: 65px;
      }

      .intro {
        font-size: 0.98rem;
      }

      .avantages-box {
        padding: 28px 22px;
      }

      .contact-section {
        padding: 24px 22px;
      }

      .btn-catalogue {
        padding: 14px 28px;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
      }

      .section-title {
        font-size: 1.08rem;
      }
    }
  </style>
</head>
<body>

